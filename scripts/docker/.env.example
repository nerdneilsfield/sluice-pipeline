# Copy this file to scripts/docker/.env and replace the values before running
# docker compose. The real .env file is gitignored.

# Prefect self-hosted server authentication uses Basic Auth.
# Browser login and local CLI clients should use this full "user:password" value.
PREFECT_AUTH_STRING=admin:change-me-to-a-long-random-password

# API URL used by the browser UI. Use your public HTTPS URL when running behind
# a reverse proxy, for example: https://prefect.example.com/api
PREFECT_UI_API_URL=http://localhost:4200/api

# Internal Docker network URL used by the sluice container.
PREFECT_API_URL=http://prefect-server:4200/api

TZ=UTC

# Container image used by docker-compose.yml and docker-compose.prefect.yml.
# Pin a version in production, for example:
# SLUICE_IMAGE=ghcr.io/nerdneilsfield/sluice-pipeline:0.2.1
SLUICE_IMAGE=ghcr.io/nerdneilsfield/sluice-pipeline:latest

# Optional secrets consumed by your sluice configs via env:NAME.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# NOTION_TOKEN=
# FEISHU_WEBHOOK_URL=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
