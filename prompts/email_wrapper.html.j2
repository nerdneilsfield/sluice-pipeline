<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pipeline_id }} · {{ run_date }}</title>
  <style>
    /* Base reset */
    body { margin: 0; padding: 0; background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; color: #1a1a1a; }
    /* Wrapper */
    .wrapper { max-width: 680px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    /* Header */
    .header { background: #18181b; color: #ffffff; padding: 20px 32px; }
    .header h1 { margin: 0; font-size: 18px; font-weight: 600; letter-spacing: .01em; }
    .header .meta { margin: 4px 0 0; font-size: 12px; color: #a1a1aa; }
    /* Body */
    .body { padding: 28px 32px; line-height: 1.7; font-size: 15px; }
    .body h1, .body h2, .body h3 { color: #111; margin-top: 1.4em; margin-bottom: .4em; }
    .body h1 { font-size: 20px; }
    .body h2 { font-size: 17px; border-bottom: 1px solid #e5e5e5; padding-bottom: 4px; }
    .body h3 { font-size: 15px; }
    .body p  { margin: .6em 0; }
    .body a  { color: #2563eb; text-decoration: none; }
    .body a:hover { text-decoration: underline; }
    .body ul, .body ol { padding-left: 1.4em; margin: .6em 0; }
    .body li { margin: .3em 0; }
    .body blockquote { margin: .8em 0; padding: 8px 16px; border-left: 3px solid #d4d4d8; color: #52525b; background: #fafafa; border-radius: 0 4px 4px 0; }
    .body code { font-family: "SFMono-Regular", Consolas, monospace; font-size: 13px; background: #f4f4f5; padding: 1px 5px; border-radius: 3px; }
    .body pre  { background: #f4f4f5; padding: 14px 16px; border-radius: 6px; overflow-x: auto; font-size: 13px; line-height: 1.5; }
    .body hr   { border: none; border-top: 1px solid #e5e5e5; margin: 1.5em 0; }
    /* Footer */
    .footer { padding: 16px 32px; background: #fafafa; border-top: 1px solid #e5e5e5; font-size: 12px; color: #71717a; }
    /* Custom styles injected from style_block_file */
    {{ style_block }}
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>{{ pipeline_id | replace("_", " ") | title }}</h1>
      <div class="meta">{{ run_date }}</div>
    </div>
    <div class="body">
      {{ body_html | safe }}
    </div>
    {% if footer %}
    <div class="footer">{{ footer }}</div>
    {% endif %}
  </div>
</body>
</html>
