<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pipeline_id | replace("_", " ") | title }} · {{ run_date }}</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; padding: 0; background: #f0f0f0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", sans-serif; color: #1a1a1a; -webkit-font-smoothing: antialiased; }

    /* ── Outer wrapper ── */
    .outer { padding: 24px 16px 40px; }
    .wrapper { max-width: 660px; margin: 0 auto; background: #fff; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.10); }

    /* ── Header ── */
    .header { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); color: #fff; padding: 28px 36px 24px; }
    .header-title { margin: 0 0 6px; font-size: 22px; font-weight: 700; letter-spacing: -.01em; }
    .header-meta { font-size: 13px; color: #94a3b8; }

    /* ── Brief block ── */
    .brief { background: #f8fafc; border-left: 4px solid #3b82f6; padding: 18px 24px; margin: 0; }
    .brief-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: #3b82f6; margin-bottom: 8px; }
    .brief p { margin: 0 0 8px; font-size: 14px; line-height: 1.75; color: #374151; }
    .brief p:last-child { margin-bottom: 0; }

    /* ── Article list ── */
    .articles { padding: 0 36px 28px; }
    .article { border-bottom: 1px solid #f0f0f0; padding: 24px 0; }
    .article:last-child { border-bottom: none; }

    .article-num { display: inline-block; font-size: 11px; font-weight: 700; color: #6b7280; background: #f3f4f6; border-radius: 4px; padding: 2px 7px; margin-bottom: 8px; }
    .article-title { margin: 0 0 4px; font-size: 17px; font-weight: 700; line-height: 1.35; }
    .article-title a { color: #0f172a; text-decoration: none; }
    .article-title a:hover { color: #2563eb; }
    .article-url { font-size: 12px; color: #9ca3af; margin-bottom: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .article-body { font-size: 14px; line-height: 1.8; color: #374151; }
    .article-body p { margin: 0 0 10px; }
    .article-body p:last-child { margin-bottom: 0; }
    .article-body strong { color: #111; }

    .article-section-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #6b7280; margin: 14px 0 6px; padding-top: 14px; border-top: 1px dashed #e5e7eb; }

    .article-meta { margin-top: 12px; font-size: 12px; color: #9ca3af; }
    .article-meta a { color: #3b82f6; text-decoration: none; }

    /* ── Footer ── */
    .footer { background: #f8fafc; border-top: 1px solid #e5e7eb; padding: 16px 36px; font-size: 12px; color: #9ca3af; text-align: center; }
    .footer a { color: #6b7280; }

    {{ style_block }}
  </style>
</head>
<body>
<div class="outer">
  <div class="wrapper">

    <div class="header">
      <div class="header-title">{{ pipeline_id | replace("_", " ") | title }}</div>
      <div class="header-meta">{{ run_date }}</div>
    </div>

    {{ body_html | safe }}

    {% if footer %}
    <div class="footer">{{ footer }}</div>
    {% endif %}

  </div>
</div>
</body>
</html>
