# ═══════════════════════════════════════════════════════════════════════════
# FEISHU BOT API COMBINATIONS
# ═══════════════════════════════════════════════════════════════════════════
# Requires Feishu app with im:message:send_as_bot scope.
# message_type: "post" or "text" only (not "interactive").

# ── A. Bot API — 综述 + 逐条 ─────────────────────────────────────────────
# [[sinks]]
# id              = "feishu_bot_all"
# type            = "feishu"
# auth_mode       = "bot_api"
# app_id          = "env:FEISHU_APP_ID"
# app_secret      = "env:FEISHU_APP_SECRET"
# receive_id      = "env:FEISHU_CHAT_ID"
# receive_id_type = "chat_id"           # "chat_id" | "open_id" | "user_id" | "email"
# message_type    = "post"
# brief_input     = "context.daily_brief"
# items_input     = "items"
# items_template  = "prompts/feishu_item.md.j2"
# split           = "per_item"
# on_message_too_long = "split_more"
# footer_template = "📅 {{ run_date }} | sluice"
# between_messages_delay_seconds = 1.0
# emit_on_empty   = false

