# ─── Pipeline: ai_news ───────────────────────────────────────────────────────
# Copy to configs/pipelines/ai_news.toml and adjust to your feeds.

id          = "ai_news"
description = "Daily AI news digest"
enabled     = true
cron        = "0 8 * * *"
timezone    = "Asia/Shanghai"
window      = "24h"
lookback_overlap = "2h"

# Sub-daily (every 6 hours):
# cron             = "0 */6 * * *"
# window           = "6h"
# run_key_template = "{pipeline_id}/{run_date}-{run_hour}"

# ─── Backpressure & cost caps ────────────────────────────────────────────────
[limits]
max_items_per_run      = 60
item_overflow_policy   = "drop_oldest"
max_llm_calls_per_run  = 600
max_estimated_cost_usd = 3.0

# ─── Failed-item lifecycle ───────────────────────────────────────────────────
[failures]
retry_failed  = true
max_retries   = 3
retry_backoff = "next_run"

# ─── Sources ─────────────────────────────────────────────────────────────────
[[sources]]
type    = "rss"
url     = "https://openai.com/blog/rss"
tag     = "ai"
timeout = 60

[[sources]]
type    = "rss"
url     = "https://www.anthropic.com/news/rss.xml"
tag     = "ai"
timeout = 60

[[sources]]
type    = "rss"
url     = "https://huggingface.co/blog/feed.xml"
tag     = "ml"
timeout = 60

# HN RSS — needed if you want hn_comments enricher to work
# [[sources]]
# type = "rss"
# url  = "https://hnrss.org/frontpage"
# tag  = "hn"

# ─── Stages ──────────────────────────────────────────────────────────────────

[[stages]]
name = "dedupe"
type = "dedupe"

# ── Cross-source dedup (optional) ────────────────────────────────────────────
# Removes duplicate items pointing to the same article across sources.
# Place before fetcher_apply to avoid fetching the same article twice.
#
# [[stages]]
# name = "cross_dedupe"
# type = "cross_dedupe"
# title_similarity_threshold = 0.85
# source_priority = ["rss_hn"]
# merge_tags = true

[[stages]]
name                      = "fetch_fulltext"
type                      = "fetcher_apply"
write_field               = "fulltext"
skip_if_field_longer_than = 2000

[[stages]]
name = "prefilter"
type = "filter"
mode = "keep_if_all"
rules = [
  { field = "fulltext",     op = "min_length",  value = 300 },
  { field = "title",        op = "not_matches",
    value = "(?i)sponsored|advertisement|广告|赞助|招聘|hiring" },
  { field = "published_at", op = "newer_than",  value = "48h" },
]

[[stages]]
name = "trim_fulltext"
type = "field_filter"
ops  = [{ op = "truncate", field = "fulltext", n = 20000 }]

# ── HTML strip (optional) ─────────────────────────────────────────────────────
# Strip HTML tags from feed fields before LLM processing.
#
# [[stages]]
# name = "strip_html"
# type = "html_strip"
# fields = ["raw_summary"]

# ── HN comments enricher (optional) ─────────────────────────────────────────
# MUST run BEFORE summarize so the LLM can incorporate community discussion.
# Checks item.url and item.guid for news.ycombinator.com/item?id=...
# Requires: pip install "sluice-pipeline[enrich-hn]"
# Also add an HN RSS source (https://hnrss.org/frontpage) to get HN items.
#
# [[stages]]
# name     = "hn_comments"
# type     = "enrich"
# enricher = "hn_comments"
# config   = { top_comments = 20, request_delay_seconds = 10.0 }

# ── Score + tag (optional) ────────────────────────────────────────────────────
# One LLM call per item: writes extras.score (1-10) and item.tags.
# Use relevance_filter after this to drop low-scored items before summarization.
# Requires: prompts/score_tag.md
#
# [[stages]]
# name = "score_and_tag"
# type = "score_tag"
# input_field    = "fulltext"
# prompt_file    = "prompts/score_tag.md"
# model          = "glm/glm-4-flash"
# workers        = 8
# on_parse_error = "skip"
# score_field    = "score"
# tags_merge     = "append"

# [[stages]]
# name = "relevance_filter"
# type = "filter"
# mode = "keep_if_all"
# rules = [{ field = "extras.score", op = "gte", value = 6 }]

[[stages]]
name              = "summarize"
type              = "llm_stage"
mode              = "per_item"
input_field       = "fulltext"
output_field      = "summary"
prompt_file       = "prompts/summarize_zh.md"
model             = "glm/glm-4-flash"
fallback_model    = "deepseek/deepseek-chat"
fallback_model_2  = "ollama/qwen2.5:14b"
workers           = 8
concurrency       = 4
timeout           = 120
max_input_chars   = 20000
truncate_strategy = "head_tail"

[[stages]]
name = "postfilter"
type = "filter"
mode = "keep_if_all"
rules = [
  { field = "summary", op = "min_length", value = 30 },
]

[[stages]]
name    = "cap"
type    = "limit"
top_n   = 20
sort_by = "published_at"

[[stages]]
name           = "daily_analysis"
type           = "llm_stage"
mode           = "aggregate"
input_field    = "summary"
output_target  = "context.daily_brief"
prompt_file    = "prompts/daily_brief_zh.md"
model          = "deepseek/deepseek-chat"
fallback_model = "openai/gpt-4o-mini"
timeout        = 180

[[stages]]
name         = "render"
type         = "render"
template     = "prompts/daily.md.j2"
output_field = "context.markdown"

# ─── Sinks ───────────────────────────────────────────────────────────────────
# Template variables:
#   items_template  — Jinja2: item, ctx, index, total
#   footer_template — Jinja2: pipeline_id, run_date, run_key
#   title_template  — str.format: {run_date}, {pipeline_id}
#   path            — str.format: {run_date}, {pipeline_id}

[[sinks]]
id    = "local"
type  = "file_md"
input = "context.markdown"
path  = "./out/ai_news/{run_date}.md"

[[sinks]]
id              = "notion_main"
type            = "notion"
input           = "context.markdown"
parent_id       = "env:NOTION_DB_AI_NEWS"
parent_type     = "database"
token           = "env:NOTION_TOKEN"
title_template  = "AI 日报 · {run_date}"
properties      = { Tag = "AI", Source = "sluice" }
mode            = "upsert"
max_block_chars = 1900

# ═══════════════════════════════════════════════════════════════════════════
# TELEGRAM SINK COMBINATIONS
# ═══════════════════════════════════════════════════════════════════════════

# ── A. 只发日报综述（一条消息）─────────────────────────────────────────────
# [[sinks]]
# id           = "tg_brief_only"
# type         = "telegram"
# bot_token    = "env:TELEGRAM_BOT_TOKEN"
# chat_id      = "env:TELEGRAM_CHAT_ID"
# brief_input  = "context.daily_brief"   # 发 daily_analysis 的输出
# items_input  = "none"                  # 不发逐条
# footer_template = "📅 {{ run_date }} | sluice"
# on_message_too_long = "split_more"
# emit_on_empty = false

# ── B. 只发逐条新闻（每条一条消息）────────────────────────────────────────
# [[sinks]]
# id              = "tg_items_only"
# type            = "telegram"
# bot_token       = "env:TELEGRAM_BOT_TOKEN"
# chat_id         = "env:TELEGRAM_CHAT_ID"
# items_input     = "items"
# items_template  = "prompts/telegram_item.md.j2"
# split           = "per_item"
# on_message_too_long = "split_more"
# footer_template = "📅 {{ run_date }} | sluice"
# between_messages_delay_seconds = 1.0
# emit_on_empty   = false

# ── C. 先发综述、再逐条（同一个 sink，同一个 chat）────────────────────────
# [[sinks]]
# id              = "tg_brief_then_items"
# type            = "telegram"
# bot_token       = "env:TELEGRAM_BOT_TOKEN"
# chat_id         = "env:TELEGRAM_CHAT_ID"
# brief_input     = "context.daily_brief"
# items_input     = "items"
# items_template  = "prompts/telegram_item.md.j2"
# split           = "per_item"
# on_message_too_long = "split_more"
# footer_template = "📅 {{ run_date }} | sluice"
# between_messages_delay_seconds = 1.0
# emit_on_empty   = false

# ── D. 所有新闻合并成一条消息──────────────────────────────────────────────
# [[sinks]]
# id              = "tg_single"
# type            = "telegram"
# bot_token       = "env:TELEGRAM_BOT_TOKEN"
# chat_id         = "env:TELEGRAM_CHAT_ID"
# items_input     = "items"
# items_template  = "prompts/telegram_item.md.j2"
# split           = "single"
# on_message_too_long = "split_more"
# footer_template = "📅 {{ run_date }} | sluice"
# emit_on_empty   = false

