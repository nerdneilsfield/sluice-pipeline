# secret          = "env:FEISHU_WEBHOOK_SECRET"
# message_type    = "post"
# brief_input     = "context.daily_brief"
# items_input     = "items"
# items_template  = "prompts/feishu_item.md.j2"
# split           = "per_item"
# on_message_too_long = "truncate"
# footer_template = "📅 {{ run_date }} | sluice"
# between_messages_delay_seconds = 1.0
# emit_on_empty   = false

# ── D. Webhook — Card V2（仅综述，不支持 split_more）────────────────────
