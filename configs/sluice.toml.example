# ─── sluice global config ────────────────────────────────────────────────────
# Copy to sluice.toml and fill in your values.
# All env: references are resolved at runtime from environment variables.

[state]
db_path = "./data/sluice.db"

# Uncomment to enable attachment mirroring (mirror_attachments stage).
# attachment_dir    = "./data/attachments"
# attachment_url_prefix = ""   # "" | "file://" | "https://cdn.example.com"

[runtime]
timezone         = "Asia/Shanghai"
default_cron     = "0 8 * * *"
prefect_api_url  = "http://localhost:4200/api"

# ─── Garbage collection ───────────────────────────────────────────────────────
[gc]
failed_items_older_than  = "90d"   # dead-lettered items older than this are purged
url_cache_older_than     = "30d"   # cache rows older than this are purged
attachments_older_than   = "60d"   # mirrored files not accessed for this long are purged

# ─── Fetcher chain ────────────────────────────────────────────────────────────
[fetcher]
chain         = ["trafilatura", "firecrawl", "jina_reader"]
min_chars     = 500
on_all_failed = "use_raw_summary"  # "skip" | "continue_empty" | "use_raw_summary"

[fetcher.cache]
enabled  = true
ttl      = "7d"
max_rows = 50000   # LRU eviction when exceeded

[fetchers.trafilatura]
type    = "trafilatura"
timeout = 120

[fetchers.firecrawl]
type     = "firecrawl"
base_url = "http://localhost:3002"
api_key  = "env:FC_KEY"
timeout  = 120

[fetchers.jina_reader]
type     = "jina_reader"
base_url = "https://r.jina.ai"
timeout  = 120
